# Ritual Chain Configuration
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
NEXT_PUBLIC_CHAIN_ID=1979

# WalletConnect Project ID (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Contract Addresses - UPDATE AFTER DEPLOYMENT
# Run: npx hardhat run scripts/deploy-contracts.js --network ritual
NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000001
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=0x0000000000000000000000000000000000000002
NEXT_PUBLIC_LOCKER_ADDRESS=0x0000000000000000000000000000000000000003
NEXT_PUBLIC_VESTING_ADDRESS=0x0000000000000000000000000000000000000004
NEXT_PUBLIC_NFT_ADDRESS=0x0000000000000000000000000000000000000005

# Faucet API (optional)
NEXT_PUBLIC_FAUCET_API_URL=https://faucet.ritualfoundation.org/api/claim

# Deployer private key (for deployment only, never commit!)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# AI API Keys (server-side only, set in Vercel dashboard)
AI_API_KEY=your_freetheai_key_here
ZEN_API_KEY=your_zen_minimax_key_here
