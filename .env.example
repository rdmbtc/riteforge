# AI API Configuration
NEXT_PUBLIC_AI_API_KEY=your_api_key_here
NEXT_PUBLIC_AI_MODEL=claude-4-5-sonnet

# AI Image Generation
NEXT_PUBLIC_AI_IMAGE_MODEL=gpt_image_2
NEXT_PUBLIC_AI_IMAGE_API_KEY=your_ai_image_api_key

# WalletConnect Project ID
# Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Ritual Chain Configuration
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws

# Supabase Configuration (Optional - for chat history persistence)
# Get from https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Connection (Optional)
DATABASE_URL=your_database_url

# Hardhat Deployment (Only needed for deploying factory contract)
# NEVER commit your private key! Use a dedicated deployment wallet
DEPLOYER_PRIVATE_KEY=your_private_key_for_deployment_only
